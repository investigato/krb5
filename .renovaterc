{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommitTypeAll(build)",
    ":separatePatchReleases",
  ],
  "branchPrefix": "renovate-",
  "rebaseWhen": "conflicted",
  "ignorePresets": [
    ":prHourlyLimit2",
    ":semanticPrefixFixDepsChoreOthers",
    "workarounds:all"
  ],
  "enabledManagers": [
    "docker-compose",
    "dockerfile",
    "github-actions",
    "gomod",
    "npm"
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ]
}
